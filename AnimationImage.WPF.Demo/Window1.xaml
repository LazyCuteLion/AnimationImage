<Window x:Class="AnimationImage.WPF.Demo.Window1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ani="https://github.com/LazyCuteLion/AnimationImage"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:AnimationImage.WPF.Demo"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="动图浏览器"
        Width="800"
        Height="450"
        mc:Ignorable="d">
    <Grid Margin="10" local:RenderingHelper.ShowFPS="True">
        <TabControl SelectionChanged="TabControl_SelectionChanged" TabStripPlacement="Bottom">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="ContentTemplate">
                        <Setter.Value>
                            <DataTemplate>
                                <ListBox ani:AnimationBehavior.AutoStart="False"
                                         ani:AnimationBehavior.ForceFPS="144"
                                         ani:AnimationBehavior.RepeatBehavior="Forever"
                                         Background="LightGray"
                                         ItemsSource="{Binding}"
                                         ScrollViewer.CanContentScroll="False"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         ScrollViewer.PanningMode="VerticalOnly">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="4" />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Margin="10"
                                                    Background="Green"
                                                    BorderBrush="Black"
                                                    BorderThickness="1">
                                                <Image ani:AnimationBehavior.AnimatableBitmap="{Binding}" MouseLeftButtonDown="Image_MouseLeftButtonDown" />
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DataTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            <TabItem Header="GIF" Tag="*.gif" />
            <TabItem Header="WebP" Tag="*.webp" />
            <TabItem Header="Lottie" Tag="*.json" />
        </TabControl>
    </Grid>
</Window>
